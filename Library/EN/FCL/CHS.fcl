// path: /library/en/steel/chs/CHS.fcl
// standard: EN
// family: CHS
// units: mm
// note: EN 10210-2 (hot-finished) and EN 10219-2 (cold-formed) circular hollow sections.
// note: d is outside diameter, t is wall thickness.

params span=1000
params d=60.3, t=3.6
params id=@($d - 2*$t)

sketch name=sec
    circle name=outer c=(0,0) r=@($d/2) mode=cr
    circle name=inner c=(0,0) r=@($id/2) mode=cr
endsketch

extrude profile=#sec distance=$span mode=add
